# Database
DB=postgres
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SCHEMA=public
DB_SSL=true

# Cloudflare R2 (S3-compatible asset storage)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=rosana-public-prod
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Sentry (optional)
ENABLE_SENTRY=false
SENTRY_DSN=

# Telemetry (optional)
IS_INSTRUMENTED=false
